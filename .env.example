OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_AUDIO_MODEL=gpt-audio-mini
OPENAI_AUDIO_VOICE=alloy
# "direct" makes one audio-model request for text and speech. Set "two_stage"
# only for an OpenAI-compatible provider that does not support audio output.
OPENAI_AUDIO_RESPONSE_MODE=direct
OPENAI_REQUEST_TIMEOUT_MS=30000
# gpt-audio-mini streams PCM16 at 24 kHz; the server wraps it as WAV for browsers.
PORT=8787
